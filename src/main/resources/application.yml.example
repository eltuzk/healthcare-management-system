spring:
  application:
    name: healthcare-backend

  # DATABASE — Oracle
  datasource:
    # Format: jdbc:oracle:thin:@<host>:<port>/<service_name>
    # Ví dụ:  jdbc:oracle:thin:@localhost:1521/XEPDB1
    url: jdbc:oracle:thin:@//161.35.109.58:1521/XEPDB1
    username: system  # Ví dụ: healthcare
    password: Test@123User
    driver-class-name: oracle.jdbc.OracleDriver

  # JPA / HIBERNATE
  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.OracleDialect

  # FLYWAY — Database migration
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    baseline-version: 2
    validate-on-migrate: true

  # MAIL — Gmail SMTP
  mail:
    host: smtp.gmail.com
    port: 587
    username: YOUR_GMAIL_ADDRESS     # Ví dụ: yourapp@gmail.com
    password: YOUR_GMAIL_APP_PASSWORD
    protocol: smtp
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# SWAGGER UI
springdoc:
  swagger-ui:
    path: /swagger-ui.html

jwt:
  secret: daylamedicalmanagementsystem
  access-token-expiration-ms: 900000
  verification-token-expiration-ms: 86400000
